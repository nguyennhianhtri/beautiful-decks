{
  "name": "beautiful-decks",
  "version": "1.0.1",
  "description": "Agent-ready HTML presentation engine for standard 16:9 and ultrawide 48:9 decks",
  "license": "MIT",
  "author": "Tri Nguyen",
  "type": "commonjs",
  "private": false,
  "bin": {
    "beautiful-decks": "bin/beautiful-decks.js"
  },
  "files": [
    "bin/",
    "engine/",
    "examples/",
    "docs/TEMPLATES.md",
    "llms.txt",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md",
    "SECURITY.md"
  ],
  "scripts": {
    "test": "node tests/engine-regressions.cjs && node tests/cli-smoke.cjs",
    "build:standard": "node bin/beautiful-decks.js build examples/standard.js dist/standard.html",
    "build:ultrawide": "node bin/beautiful-decks.js build examples/ultrawide.js dist/ultrawide.html",
    "build:gallery:standard": "node bin/beautiful-decks.js build examples/template-gallery.js dist/template-gallery.html",
    "build:gallery:ultrawide": "node bin/beautiful-decks.js build examples/ultrawide-gallery.js dist/ultrawide-gallery.html",
    "build:galleries": "npm run build:gallery:standard && npm run build:gallery:ultrawide",
    "build:examples": "npm run build:standard && npm run build:ultrawide && npm run build:galleries",
    "qa:standard": "node bin/beautiful-decks.js qa dist/standard.html --out dist/qa-standard",
    "qa:ultrawide": "node bin/beautiful-decks.js qa dist/ultrawide.html --out dist/qa-ultrawide --dsf 1",
    "qa:gallery:standard": "node bin/beautiful-decks.js qa dist/template-gallery.html --out dist/qa-template-gallery --settle 0",
    "qa:gallery:ultrawide": "node bin/beautiful-decks.js qa dist/ultrawide-gallery.html --out dist/qa-ultrawide-gallery --settle 0 --dsf 0.5",
    "qa:galleries": "npm run qa:gallery:standard && npm run qa:gallery:ultrawide",
    "qa:examples": "npm run qa:standard && npm run qa:ultrawide && npm run qa:galleries",
    "safety": "node scripts/check-public-safety.cjs",
    "verify": "npm test && npm run build:examples && npm run qa:examples && npm run safety"
  },
  "keywords": [
    "presentations",
    "slides",
    "html",
    "16:9",
    "ultrawide",
    "llms.txt",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^23.11.1"
  }
}
